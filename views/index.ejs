<%- include("partials/header", { pageTitle }) %>

<section class="discovery-hero">
  <div class="container">
    <div class="landing-shell">
      <p class="eyebrow">Vibe-first music discovery</p>
      <h1 class="landing-title">Start with a mood. Find something worth replaying.</h1>
      <p class="landing-copy">
        Describe the sound you want and LyricColor will surface playable Deezer previews,
        artist mixes, and tracks you can save for later.
      </p>

      <form
        class="vibe-form landing-form js-load-form"
        action="/songs/search"
        method="GET"
        data-loading-message="Mapping your vibe..."
      >
        <label class="sr-only" for="q">Describe the vibe you want</label>
        <textarea
          id="q"
          name="q"
          rows="2"
          placeholder="glossy city lights, smoky soul, restless club energy..."
          required
        ></textarea>
        <button type="submit" data-loading-label="Mapping...">Find My Sound</button>
      </form>

      <div class="prompt-strip prompt-strip-top">
      <% starterPrompts.forEach((prompt) => { %>
        <a
          class="prompt-pill js-load-link"
          href="/songs/search?q=<%= encodeURIComponent(prompt) %>"
          data-loading-message="Opening discovery results..."
        >
          <%= prompt %>
        </a>
      <% }) %>
      </div>

      <div class="landing-footer">
        <a class="saved-link" href="/songs/saved">Open saved tracks</a>
        <p class="hero-note">Search by mood, scene, energy, texture, or whatever else gets you close.</p>
      </div>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
